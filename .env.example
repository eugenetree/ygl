# Docker
DOCKERFILE=Dockerfile.dev
STOP_GRACE_PERIOD=10m

# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db
DB_HOST=host
DB_PORT=1234

# Elasticsearch
ES_NODE=http://elasticsearch:9200

# Telegram notifications
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# VPN Credentials for Scraper
VPN_USER=your_username
VPN_PASS=your_password
VPN_CONFIG_B64=router_config.ovpn_in_b64

# yt-dlp cookies — needed when YouTube requires auth ("Sign in to confirm you're not a bot")
# Export cookies.txt from your browser, then: base64 -w 0 cookies.txt
YTDLP_COOKIES_B64=cookies_b64
