[
  {
    "startTime": 13263,
    "endTime": 15390,
    "duration": 2127,
    "text": "No doubt you've seen\nthe chaos in the streets."
  },
  {
    "startTime": 18268,
    "endTime": 19769,
    "duration": 1501,
    "text": "We must make an example"
  },
  {
    "startTime": 19769,
    "endTime": 20937,
    "duration": 1168,
    "text": "or France will fall."
  },
  {
    "startTime": 24149,
    "endTime": 27569,
    "duration": 3420,
    "text": "What would you do if this assignment\nof defense was transferred to you?"
  },
  {
    "startTime": 35035,
    "endTime": 36870,
    "duration": 1835,
    "text": "I promise you brilliant successes."
  },
  {
    "startTime": 48423,
    "endTime": 50216,
    "duration": 1793,
    "text": "What is this costume you have on?"
  },
  {
    "startTime": 50258,
    "endTime": 51342,
    "duration": 1084,
    "text": "This is my uniform."
  },
  {
    "startTime": 55346,
    "endTime": 57140,
    "duration": 1794,
    "text": "I led the French victory at Toulon."
  },
  {
    "startTime": 61519,
    "endTime": 62312,
    "duration": 793,
    "text": "What is your name?\n "
  },
  {
    "startTime": 62771,
    "endTime": 63480,
    "duration": 709,
    "text": "Napoleon."
  },
  {
    "startTime": 63938,
    "endTime": 65857,
    "duration": 1919,
    "text": "Has the course of my life just changed..."
  },
  {
    "startTime": 66316,
    "endTime": 67150,
    "duration": 834,
    "text": "Napoleon?"
  },
  {
    "startTime": 70278,
    "endTime": 71780,
    "duration": 1502,
    "text": "I am destined for greatness."
  },
  {
    "startTime": 73531,
    "endTime": 75867,
    "duration": 2336,
    "text": "But those in power only see me as a sword."
  },
  {
    "startTime": 77118,
    "endTime": 79954,
    "duration": 2836,
    "text": "I suggest you take the throne as king."
  },
  {
    "startTime": 86711,
    "endTime": 87629,
    "duration": 918,
    "text": "Shall we vote?"
  },
  {
    "startTime": 89172,
    "endTime": 90924,
    "duration": 1752,
    "text": "Long live the emperor! "
  },
  {
    "startTime": 91424,
    "endTime": 93176,
    "duration": 1752,
    "text": "Long live the emperor!"
  },
  {
    "startTime": 96054,
    "endTime": 99015,
    "duration": 2961,
    "text": "This vermin has held the world hostage..."
  },
  {
    "startTime": 99974,
    "endTime": 103520,
    "duration": 3546,
    "text": "with his egotism and his lack\nof simple good manners."
  },
  {
    "startTime": 110110,
    "endTime": 111277,
    "duration": 1167,
    "text": "You think you're great."
  },
  {
    "startTime": 114114,
    "endTime": 116533,
    "duration": 2419,
    "text": "You're just a tiny little brute"
  },
  {
    "startTime": 116533,
    "endTime": 118660,
    "duration": 2127,
    "text": "that is nothing without me."
  },
  {
    "startTime": 120954,
    "endTime": 123248,
    "duration": 2294,
    "text": "All of Europe is uniting forces against me."
  },
  {
    "startTime": 123706,
    "endTime": 125750,
    "duration": 2044,
    "text": "What's the outcome of this\nif you don't succeed?"
  },
  {
    "startTime": 128711,
    "endTime": 130588,
    "duration": 1877,
    "text": "Your majesty, we are discovered."
  },
  {
    "startTime": 130922,
    "endTime": 131464,
    "duration": 542,
    "text": "Good."
  },
  {
    "startTime": 133174,
    "endTime": 134050,
    "duration": 876,
    "text": "Ice!"
  },
  {
    "startTime": 134134,
    "endTime": 135009,
    "duration": 875,
    "text": "It's a trap!"
  },
  {
    "startTime": 136344,
    "endTime": 138429,
    "duration": 2085,
    "text": "I'm the first to admit\nwhen I make a mistake..."
  },
  {
    "startTime": 143810,
    "endTime": 145019,
    "duration": 1209,
    "text": "I simply never do."
  }
]