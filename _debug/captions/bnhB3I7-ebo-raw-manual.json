    "startTime": 493326,
    "endTime": 495061,
    "duration": 1735,
    "text": "IT'S A HUGE BREAK."
  },
  {
    "startTime": 494193,
    "endTime": 496729,
    "duration": 2536,
    "text": "I'M SO HAPPY."
  },
  {
    "startTime": 495394,
    "endTime": 499232,
    "duration": 3838,
    "text": "IT JUST DOESN'T SEEM LIKE THE"
  },
