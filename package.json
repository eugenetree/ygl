{
  "name": "youglish",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npx nodemon",
    "db:migration:run": "npx tsx src/db/scripts/run-migrations.ts",
    "db:migration:rollback": "npx tsx src/db/scripts/rollback-migration.ts",
    "db:migration:create-new": "npx tsx src/db/scripts/create-migration-file.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "echo \"Error: no test specified\" && exit 1",
    "format": "prettier . --write",
    "start": "npx tsx src/index.ts",
    "build": "rm -rf dist && npx tsc && node dist/src/modules/scrapers/bootstrap.js",
    "build:channel-videos": "rm -rf dist && npx tsc && node dist/src/modules/scrapers/channel-videos/runtime/bootstrap.js",
    "t": "npx tsc && node dist/test2.js",
    "run:channels-direct": "npx tsc && node dist/src/modules/scrapers/channels/runtime/bootstrap-direct.js",
    "run:channels-via-videos": "npx tsc && node dist/src/modules/scrapers/channels/runtime/bootstrap-via-videos.js",
    "run:channel-videos": "npx tsc && node dist/src/modules/scrapers/channel-videos/runtime/bootstrap.js",
    "run:captions-search": "npx tsc && node dist/src/modules/captions-search/bootstrap.js",
    "find-captions": "npx tsc && node dist/src/modules/captions-search/find-captions-bootstrap.js",
    "run:all": "npx tsc && node dist/src/modules/scrapers/channels/bootstrap.js & node dist/src/modules/scrapers/channel-videos/runtime/bootstrap.js",
    "go:direct": "npm run db:migration:run && npx tsc && node dist/src/modules/scrapers/channels/runtime/bootstrap-direct.js",
    "go:via-videos": "npm run db:migration:run && npx tsc && node dist/src/modules/scrapers/channels/runtime/bootstrap-via-videos.js",
    "go:all": "npx tsc && node dist/src/modules/scrapers/bootstrap.js",
    "export:captions": "npx tsc captions.ts",
    "debug:fetch-captions": "npx tsx _debug/fetch-video-captions.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.26.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.6",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "globals": "^16.1.0",
    "nodemon": "^3.1.4",
    "prettier": "3.5.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.32.0"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.0",
    "axios": "^1.7.7",
    "inversify": "^7.9.1",
    "kysely": "^0.27.5",
    "lodash-es": "^4.17.21",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "valibot": "^0.37.0",
    "youtube-search-api": "^1.2.2",
    "zod": "^3.23.8"
  }
}