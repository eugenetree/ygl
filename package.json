{
  "name": "youglish",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npx nodemon",
    "db:migration:run": "npx tsx src/db/scripts/run-migrations.ts",
    "db:migration:rollback": "npx tsx src/db/scripts/rollback-migration.ts",
    "db:migration:create-new": "npx tsx src/db/scripts/create-migration-file.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "node --test --import tsx \"src/**/*.test.ts\"",
    "format": "prettier . --write",
    "clean": "rm -rf dist/*",
    "start": "npm run clean && npx tsx src/index.ts",
    "build": "npm run clean && tsc",
    "run:channel-discovery": "npm run clean && tsc && node dist/src/modules/scrapers/channel-discovery/bootstrap.js",
    "run:channel": "npm run clean && tsc && node dist/src/modules/scrapers/channel/bootstrap.js",
    "run:video-discovery": "npm run clean && tsc && node dist/src/modules/scrapers/video-discovery/bootstrap.js",
    "run:video": "npm run clean && tsc && node dist/src/modules/scrapers/video/bootstrap.js",
    "run:captions-search": "npm run clean && tsc && node dist/src/modules/captions-search/bootstrap.js",
    "sync:elastic": "npm run clean && tsc && node dist/src/modules/captions-search/bootstrap.js",
    "resync:elastic": "npm run clean && tsc && node dist/src/modules/captions-search/resync-bootstrap.js",
    "find-captions": "npm run clean && tsc && node dist/src/modules/captions-search/find-captions-bootstrap.js",
    "run:all": "npm run clean && tsc && node dist/src/modules/scrapers/bootstrap.js",
    "run:scrapers": "npm run clean && tsc && node dist/src/modules/scrapers/main.js",
    "main": "npm run clean && tsc && node dist/src/main.js",
    "export:captions": "tsc captions.ts",
    "debug:fetch-captions": "npx tsx _debug/fetch-video-captions.ts",
    "run:reprocess-captions": "npm run clean && tsc && node dist/src/modules/scrapers/video/use-cases/reprocess-captions/bootstrap.js",
    "start:bot": "npm run db:migration:run && npm run clean && tsc && node dist/src/main-bot.js",
    "start:scraper": "npm run db:migration:run && npm run clean && tsc && node dist/src/main-scraper.js",
    "start:elastic": "npm run db:migration:run && npm run clean && tsc && node dist/src/main-elastic.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.26.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/adm-zip": "^0.5.8",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "globals": "^16.1.0",
    "nodemon": "^3.1.4",
    "prettier": "3.5.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.32.0"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.13.9",
    "@types/pg": "^8.11.6",
    "adm-zip": "^0.5.17",
    "axios": "^1.7.7",
    "compromise": "^14.15.0",
    "inversify": "^7.9.1",
    "kysely": "^0.27.5",
    "lodash-es": "^4.17.21",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "telegraf": "^4.16.3",
    "valibot": "^0.37.0",
    "youtube-search-api": "^1.2.2",
    "ytdlp-nodejs": "^3.4.2",
    "zod": "^3.23.8"
  }
}
